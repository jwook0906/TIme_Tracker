{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkTimeTracker",
  "version": "1.1.0",
  "identifier": "com.jwook.timetracker",
  "build": {
    "frontendDist": "../renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "작업시간 측정기",
        "width": 700,
        "height": 640,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "createUpdaterArtifacts": true,
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/<GITHUB_USER>/<GITHUB_REPO>/releases/latest/download/latest.json"
      ],
      "pubkey": "<TAURI_UPDATER_PUBKEY>"
    }
  }
}
